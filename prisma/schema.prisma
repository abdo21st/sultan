generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  ACCOUNTANT
  USER
}

model User {
  id          String  @id @default(cuid())
  username    String  @unique
  password    String // Hashed password
  displayName String
  phoneNumber String? // For WhatsApp notifications
  role        Role    @default(USER) // Legacy Enum, kept for safe migration

  // New Relation
  roleRel CustomRole? @relation(fields: [roleId], references: [id])
  roleId  String?

  permissions String[] @default([]) // Overrides or extra permissions
  facilityId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CustomRole {
  id          String   @id @default(cuid())
  name        String   @unique // e.g. "ADMIN", "MANAGER"
  displayName String
  permissions String[]
  users       User[]
}

model SystemSettings {
  id          String   @id @default("default") // Singleton row
  appName     String   @default("سلطان")
  logoUrl     String?
  printHeader String?
  printFooter String?
  themeColor  String   @default("#d97706") // Default amber
  updatedAt   DateTime @updatedAt
}

model Facility {
  id       String  @id @default(cuid())
  name     String
  type     String
  location String?
}

model Order {
  id              String   @id @default(cuid())
  serialNumber    Int      @default(autoincrement())
  customerName    String
  customerPhone   String
  description     String
  dueDate         String
  status          String   @default("REGISTERED")
  totalAmount     Float
  paidAmount      Float
  remainingAmount Float    @default(0)
  images          String[]
  factoryId       String
  shopId          String
  rejectionReason String?
  paymentNote     String?
  history         Json[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([factoryId])
  @@index([shopId])
  @@index([status])
  @@index([customerPhone])
}

model Transaction {
  id          String   @id @default(cuid())
  type        String
  amount      Float
  category    String
  description String?
  date        DateTime @default(now())
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}
