generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  ACCOUNTANT
  USER
}

model User {
  id          String  @id @default(cuid())
  username    String  @unique
  password    String // Hashed password
  displayName String
  phoneNumber String? // For WhatsApp notifications
  role        Role    @default(USER) // Legacy Enum, kept for safe migration

  // New Relation: Multi-role support
  roles CustomRole[]

  permissions String[] @default([]) // Overrides or extra permissions
  facilityId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CustomRole {
  id          String   @id @default(cuid())
  name        String   @unique // e.g. "ADMIN", "MANAGER"
  displayName String
  description String?
  permissions String[]
  users       User[]
}

model SystemSettings {
  id          String   @id @default("default") // Singleton row
  appName     String   @default("سلطان")
  logoUrl     String?
  printHeader String?
  printFooter String?
  themeColor  String   @default("#d97706") // Default amber
  updatedAt   DateTime @updatedAt
}

model Facility {
  id       String  @id @default(cuid())
  name     String
  type     String
  location String?

  factoryOrders Order[] @relation("FactoryOrders")
  shopOrders    Order[] @relation("ShopOrders")
}

model Order {
  id              String   @id @default(cuid())
  serialNumber    Int      @default(autoincrement())
  customerName    String
  customerPhone   String
  description     String
  dueDate         DateTime
  status          String   @default("orders:status:registered")
  totalAmount     Float
  paidAmount      Float
  remainingAmount Float    @default(0)
  images          String[]
  factoryId       String
  factory         Facility @relation("FactoryOrders", fields: [factoryId], references: [id])
  shopId          String
  shop            Facility @relation("ShopOrders", fields: [shopId], references: [id])
  rejectionReason String?
  paymentNote     String?
  history         Json[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([factoryId])
  @@index([shopId])
  @@index([status])
  @@index([customerPhone])
}

model Transaction {
  id          String   @id @default(cuid())
  type        String
  amount      Float
  category    String
  description String?
  orderId     String? // Link to specific Order
  customerId  String? // Link to specific Customer (if we normalize customers later)
  date        DateTime @default(now())
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([orderId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

model CapacityRule {
  id           String    @id @default(cuid())
  factoryId    String? // Null means applies to all factories
  dayOfWeek    Int? // 0-6 (Sunday-Saturday), null means specific date
  specificDate DateTime?
  maxCapacity  Int
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([factoryId])
  @@index([dayOfWeek])
  @@index([specificDate])
}

model AlertSetting {
  id              String   @id @default(cuid())
  name            String
  triggerStatus   String // e.g., "REGISTERED", "DELIVERED"
  timingDays      Int      @default(0) // 0 means at the day, -1 means day before
  whatsappEnabled Boolean  @default(false)
  recipientPhones String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
