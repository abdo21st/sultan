generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  ACCOUNTANT
  USER
}

model User {
  id          String   @id @default(cuid())
  username    String   @unique
  password    String // Hashed password
  displayName String
  role        Role     @default(USER)
  permissions String[] @default([]) // For granular permissions e.g. ["MANAGE_USERS", "VIEW_REPORTS"]
  facilityId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemSettings {
  id          String   @id @default("default") // Singleton row
  appName     String   @default("سلطان")
  logoUrl     String?
  printHeader String?
  printFooter String?
  themeColor  String   @default("#d97706") // Default amber
  updatedAt   DateTime @updatedAt
}

model Facility {
  id       String  @id @default(cuid())
  name     String
  type     String
  location String?
}

model Order {
  id              String   @id @default(cuid())
  customerName    String
  customerPhone   String
  description     String
  dueDate         String
  status          String   @default("REGISTERED")
  totalAmount     Float
  paidAmount      Float
  remainingAmount Float    @default(0)
  imageUrl        String?
  factoryId       String
  shopId          String
  history         Json[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Transaction {
  id          String   @id @default(cuid())
  type        String
  amount      Float
  category    String
  description String?
  date        DateTime @default(now())
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
